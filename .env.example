# ============================================
# Nutri B2C Backend — Environment Variables
# Copy to .env.local and fill in your values.
# Keep real secrets out of source control.
# ============================================

# --- Runtime ---
NODE_ENV=development
PORT=5000
HOST=127.0.0.1
TRUST_PROXY=1

# --- Database (Supabase pooled connection) ---
# Get from Supabase → Settings → Database → "Transaction pooler"
# URL-encode special characters in the password
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Optional read replica (falls back to DATABASE_URL if unset)
# DATABASE_REPLICA_URL=

# --- Supabase (server-side storage) ---
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Appwrite (cloud auth) ---
# Get from Appwrite Console → Project Settings
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
ADMINS_TEAM_ID=
APPWRITE_DB_ID=nutrition_db
APPWRITE_PROFILES_COLLECTION_ID=profiles
APPWRITE_HEALTH_COLLECTION_ID=health_profiles

# --- CORS ---
# Comma-separated allowed browser origins. Supports wildcard patterns.
CORS_ALLOW_ALL=0
WEB_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,https://nutri-b2c-frontend.vercel.app,https://nutri-b2c-frontend-*.vercel.app

# --- Rate Limiting ---
RATE_LIMITS_READ_RPM=60
RATE_LIMITS_WRITE_RPM=6

# --- LLM / LiteLLM ---
# Base URL for LiteLLM proxy
LITELLM_BASE_URL=https://litellm.confer.today/v1
# API keys — do NOT commit real keys, use .env.local
LITELLM_API_KEY=
LITELLM_API_KEY_VISION=
# Model selection (proxy requires "openai/" prefix)
LLM_MODEL=openai/gpt-5-nano
LLM_VISION_MODEL=openai/gpt-5-mini

# --- AI Meal Planner ---
MEAL_PLAN_LLM_MODEL=gpt-4o-mini
MEAL_PLAN_MAX_RECIPES=50
MEAL_PLAN_TIMEOUT_MS=60000
MEAL_PLAN_LLM_COOLDOWN_MS=120000
MEAL_PLAN_SWAP_TIMEOUT_MS=30000

# --- RAG Pipeline (optional — FastAPI sidecar) ---
# RAG_API_URL=http://localhost:8000
# RAG_API_KEY=

# --- Graph Feature Flags (all OFF by default) ---
USE_GRAPH_SEARCH=false
USE_GRAPH_FEED=false
USE_GRAPH_MEAL_PLAN=false
USE_GRAPH_GROCERY=false
USE_GRAPH_SCANNER=false
USE_GRAPH_MEAL_LOG=false
USE_GRAPH_CHATBOT=false
